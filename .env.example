# ============================================================
# TikTok UGC Automation Engine — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# === PHASE 1 MINIMUM (only these two are required to start) ===
ANTHROPIC_API_KEY=
PEXELS_API_KEY=

# === OPTIONAL: Cheaper model routing ===
# GROQ_API_KEY=             # Free Groq API — use for classification agents
# GEMINI_API_KEY=           # Google Gemini Flash ($0.10/M) — Sonnet fallback

# === DATABASE ===
# Phase 1-2: SQLite (zero setup, zero cost)
USE_SQLITE=true
SQLITE_DB_PATH=.tmp/database.db
# Phase 2+: Supabase (comment out USE_SQLITE=true when ready)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# === MONEYPRINTER TURBO ===
MPT_BASE_URL=http://127.0.0.1:8080
MPT_API_TIMEOUT=300

# === FIRECRAWL (already configured as MCP — also add here for script use) ===
FIRECRAWL_API_KEY=

# === TIKTOK (Official OAuth 2.0 ONLY — apply at developers.tiktok.com) ===
# Approval takes 1-4 weeks — apply NOW even if you won't use it for months
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_REFRESH_TOKEN=
TIKTOK_OPEN_ID=
TIKTOK_REDIRECT_URI=http://localhost:8000/callback

# === NOTIFICATIONS ===
SLACK_WEBHOOK_URL=
# Gmail SMTP alternative (free):
# GMAIL_USER=
# GMAIL_APP_PASSWORD=

# === TRIGGER.DEV (Phase 4+) ===
TRIGGER_SECRET_KEY=
TRIGGER_PROJECT_ID=

# === STORAGE PATHS ===
VIDEO_OUTPUT_DIR=.tmp/videos
SCRIPTS_OUTPUT_DIR=.tmp/scripts

# ============================================================
# SAFETY FLAGS — Change ONLY when explicitly ready
# ============================================================
POSTING_ENABLED=false           # MUST stay false until Phase 6
DRAFT_UPLOAD_ENABLED=false      # Set true in Phase 5 ONLY
HUMAN_REVIEW_REQUIRED=true      # NEVER disable this
MAX_VIDEOS_PER_DAY=3

# === AUDIENCE TRANSITION ===
TRANSITION_PHASE=1              # 1-4 — update manually as audience shifts
TRANSITION_FEMALE_TARGET_PCT=70

# === A/B TESTING (Phase 4+) ===
AB_TEST_ENABLED=false
